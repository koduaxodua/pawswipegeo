# Supabase project credentials (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only Vercel Function env vars. Never expose these with VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ADMIN_PASSWORD_HASH=pbkdf2_sha256$210000$replace-with-random-salt$replace-with-derived-hex-hash
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
